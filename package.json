{
  "name": "p-setup",
  "version": "0.1.0",
  "description": "Intelligent project setup & management CLI. Auto-detects your stack, installs dependencies, configures environments, and keeps projects healthy.",
  "type": "module",
  "bin": {
    "setup": "./dist/cli.js",
    "p-setup": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.js",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": ["cli", "setup", "project", "development", "tui", "ai"],
  "author": "Evan Lu",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "ink": "^5.1.0",
    "ink-text-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "react": "^18.3.1",
    "chalk": "^5.4.1",
    "meow": "^13.2.0",
    "zustand": "^5.0.3",
    "openai": "^4.78.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "tsup": "^8.3.5",
    "eslint": "^9.15.0",
    "vitest": "^2.1.8",
    "ink-testing-library": "^4.0.0"
  }
}
